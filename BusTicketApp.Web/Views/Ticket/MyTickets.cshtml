@model IEnumerable<BusTicketApp.Domain.Models.Ticket>

@{
    ViewData["Title"] = "My Tickets";
}

<h2>My Tickets</h2>

@if (!Model.Any())
{
    <p>You have no tickets.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Route</th>
                <th>Destination</th>
                <th>Departure</th>
                <th>Booking Date</th>
                <th>Seat</th>
                <th></th>   
            </tr>
        </thead>
        <tbody>
            @foreach (var ticket in Model)
            {
                <tr>
                    <td>@ticket.BusRoute?.RouteName</td>
                    <td>@ticket.BusRoute?.DestinationTown</td>
                    <td>@ticket.BusRoute?.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@ticket.BookingDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@ticket.SeatNumber</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@ticket.Id">Details</a> |
                        <a asp-action="Delete" asp-route-id="@ticket.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
