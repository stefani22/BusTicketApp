@model BusTicketApp.Domain.DTO.RouteCountryInfoDto

@{
    ViewData["Title"] = "Ticket Details";
}

<div class="container mt-4 mb-5">

    <h2 class="mb-4">Ticket details</h2>

    <div class="row g-4">

        <!-- LEFT: TICKET  -->
        <div class="col-md-7">
            <div class="card shadow-lg" style="border-radius:16px; border-left:6px solid #0d6efd;">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div>
                            <h5 class="mb-1">🚌 @Model.RouteName</h5>
                            <small class="text-muted">
                                @Model.FromStationTown → @Model.DestinationTown
                            </small>
                        </div>

                        
                        <img src="https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?auto=format&fit=crop&w=300&q=80"
                             alt="Bus"
                             style="width:70px; height:45px; object-fit:cover; border-radius:8px;">
                    </div>

                    <hr />

                    <div class="row mb-2">
                        <div class="col-4 fw-bold">From station</div>
                        <div class="col-8">
                            @Model.FromStationName (@Model.FromStationTown)
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Destination</div>
                        <div class="col-8">
                            @Model.DestinationTown (@Model.DestinationCountry)
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Departure</div>
                        <div class="col-8">
                            @Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>

                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Price</div>
                        <div class="col-8">
                            @Model.Price MKD
                        </div>
                    </div>

                    

                    <div class="row mb-2">
                        <div class="col-4 fw-bold">Distance</div>
                        <div class="col-8">
                            @Model.DistanceKm km
                        </div>
                    </div>

                    <div class="row mb-0">
                        <div class="col-4 fw-bold">Estimated time</div>
                        <div class="col-8">
                            @Model.EstimatedHours h
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- RIGHT: EXTRA COUNTRY INFO (API) -->
        <div class="col-md-5">
            <div class="card shadow-sm h-100"
                 style="
        background-color: #e7f1ff;
        border-left: 6px solid #0d6efd;
        border-radius: 16px;
     ">
                <div class="card-body">


                    <h5 class="mb-2 text-primary">
                        🌍 Extra information about your destination country
                    </h5>

                    <span class="badge bg-primary mb-3">
                        External API data
                    </span>


                    @if (!string.IsNullOrEmpty(Model.CountryName))
                    {
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Country</dt>
                            <dd class="col-sm-8">@Model.CountryName</dd>

                            <dt class="col-sm-4">Capital</dt>
                            <dd class="col-sm-8">@Model.Capital</dd>

                           

                            <dt class="col-sm-4">Population</dt>
                            <dd class="col-sm-8">
                                @Model.PopulationInMillions.ToString("0.00") M
                            </dd>

                            <dt class="col-sm-4">Big country?</dt>
                            <dd class="col-sm-8">
                                @(Model.IsBigCountry
                                                            ? "Yes (more than 5M inhabitants)"
                                                            : "No (5M or less)")
                        </dd>
                    </dl>
                                        }
                    else
                    {
                        <p><em>No country info available from API.</em></p>
                    }

                </div>
            </div>
        </div>

    </div>

    <div class="mt-4">
        <a asp-action="MyTickets"
           class="btn btn-outline-secondary">
            Back to list
        </a>
    </div>

</div>
