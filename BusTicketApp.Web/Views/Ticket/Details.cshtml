@model BusTicketApp.Domain.DTO.RouteCountryInfoDto

@{
    ViewData["Title"] = "Ticket Details";
}

<h2>Ticket Details</h2>

<h4>Route Information</h4>
<hr />
<dl class="row">
    <dt class="col-sm-2">Route</dt>
    <dd class="col-sm-10">@Model.RouteName</dd>

    <dt class="col-sm-2">From station</dt>
    <dd class="col-sm-10">@Model.FromStationName (@Model.FromStationTown)</dd>

    <dt class="col-sm-2">Destination</dt>
    <dd class="col-sm-10">@Model.DestinationTown (@Model.DestinationCountry)</dd>

    <dt class="col-sm-2">Departure</dt>
    <dd class="col-sm-10">@Model.DepartureTime.ToString("dd.MM.yyyy HH:mm")</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price</dd>

    <dt class="col-sm-2">Available seats</dt>
    <dd class="col-sm-10">@Model.AvailableSeats</dd>

    <dt class="col-sm-2">Distance</dt>
    <dd class="col-sm-10">@Model.DistanceKm} km</dd>

    <dt class="col-sm-2">Estimated time</dt>
    <dd class="col-sm-10">@Model.EstimatedHours h</dd>
</dl>

<h4>Destination Country Info (from API)</h4>
<hr />

@if (!string.IsNullOrEmpty(Model.CountryName))
{
    <dl class="row">
        <dt class="col-sm-2">Country</dt>
        <dd class="col-sm-10">@Model.CountryName</dd>

        <dt class="col-sm-2">Capital</dt>
        <dd class="col-sm-10">@Model.Capital</dd>

        <dt class="col-sm-2">Region</dt>
        <dd class="col-sm-10">@Model.Region</dd>

        <dt class="col-sm-2">Population</dt>
        <dd class="col-sm-10">@Model.PopulationInMillions.ToString("0.00") M</dd>

        <dt class="col-sm-2">Big country?</dt>
        <dd class="col-sm-10">
            @(Model.IsBigCountry ? "Yes (more than 5M)" : "No (5M or less)")
        </dd>
    </dl>
}
else
{
    <p><em>No country info available from API.</em></p>
}

<p>
    <a asp-action="MyTickets">Back to List</a>
</p>
