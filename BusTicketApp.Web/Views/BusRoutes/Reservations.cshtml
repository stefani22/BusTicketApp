@model BusTicketApp.Domain.DTO.RouteTicketsViewModel

@{
    ViewData["Title"] = "Route reservations";
}


<div class="container mt-4">
    <h2 class="mb-3">
        Reservations for <strong>@Model.Route.RouteName</strong>
    </h2>

    <div class="card shadow-sm mb-4" style="background-color:#bbdefb;">
        <div class="card-body">
            
            <p class="mb-1">
                <strong>Departure:</strong>
                @Model.Route.DepartureTime.ToString("dd.MM.yyyy HH:mm")
            </p>
            <p class="mb-0">
                <strong>Available seats:</strong>
                @Model.Route.AvailableSeats
            </p>
        </div>
    </div>

    @if (Model.Tickets == null || !Model.Tickets.Any())
    {
        <div class="alert alert-info">
            <em>No reservations for this route yet.</em>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-header" style="background-color:#64b5f6;">
                <strong>Reservations (@Model.Tickets.Count())</strong>
            </div>
            <div class="card-body p-0" style="background-color:#f5f5f5;">
                <table class="table mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Email</th>
                            <th>Seat</th>
                            <th>Booking date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ticket in Model.Tickets)
                        {
                            <tr>
                                <td>@ticket.AppUser?.Email</td>
                                <td>@ticket.SeatNumber</td>
                                <td>@ticket.BookingDate.ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3">
        <a asp-action="Details"
           asp-route-id="@Model.Route.Id"
           class="btn btn-outline-secondary">
            Back to route details
        </a>
    </div>
</div>
