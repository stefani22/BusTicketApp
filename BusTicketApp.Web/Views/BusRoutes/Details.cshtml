@model BusTicketApp.Domain.DTO.RouteTicketsViewModel

@{
    ViewData["Title"] = "Route Details";
}

<h1>Route Details</h1>

<div>
    <h4>Bus Route</h4>
    <hr />
    <dl class="row">

        <dt class="col-sm-2">Route name</dt>
        <dd class="col-sm-10">@Model.Route.RouteName</dd>

        <dt class="col-sm-2">Destination town</dt>
        <dd class="col-sm-10">@Model.Route.DestinationTown</dd>

        <dt class="col-sm-2">Destination country</dt>
        <dd class="col-sm-10">@Model.Route.DestinationCountry</dd>

        <dt class="col-sm-2">Departure time</dt>
        <dd class="col-sm-10">
            @Model.Route.DepartureTime.ToString("dd.MM.yyyy HH:mm")
        </dd>

        <dt class="col-sm-2">Price</dt>
        <dd class="col-sm-10">@Model.Route.Price</dd>

        <dt class="col-sm-2">Available seats</dt>
        <dd class="col-sm-10">@Model.Route.AvailableSeats</dd>

        <dt class="col-sm-2">Distance (km)</dt>
        <dd class="col-sm-10">@Model.Route.DistanceKm</dd>

        <dt class="col-sm-2">Estimated hours</dt>
        <dd class="col-sm-10">@Model.Route.EstimatedHours</dd>

        <dt class="col-sm-2">Bus station</dt>
        <dd class="col-sm-10">@Model.Route.BusStation?.Name</dd>

    </dl>
</div>

<hr />

<div class="mt-3">
    @if (Model.Tickets != null && Model.Tickets.Any())
    {
        <a asp-action="Reservations"
           asp-route-id="@Model.Route.Id"
           class="btn btn-info">
            View tickets (@Model.Tickets.Count())
        </a>
    }
    else
    {
        <span class="text-muted">
            No tickets yet
        </span>
    }


    <a asp-action="Edit"
       asp-route-id="@Model.Route.Id"
       class="btn btn-warning">
        Edit
    </a>

    <a asp-action="Index"
       class="btn btn-secondary">
        Back to list
    </a>
</div>
