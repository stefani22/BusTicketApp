@model BusTicketApp.Domain.DTO.RouteTicketsViewModel

@{
    ViewData["Title"] = "Route Details";
}


<div style="
    background-image: url('/images/img13.jpg');
    background-size: cover;
    background-position: center;
    padding: 70px 0;
">
    <div class="container text-white">
        <h1 style="font-weight:700;">
            @Model.Route.RouteName
        </h1>
        <p class="mb-0">
            Route details
        </p>
    </div>
</div>

<div class="container mt-5">

    <div class="card shadow-sm">
        <div class="card-body">

            <h5 class="mb-4">🚌 Route information</h5>

            <div class="row mb-2">
                <div class="col-md-4 fw-bold">Route name</div>
                <div class="col-md-8">@Model.Route.RouteName</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4 fw-bold">Bus Station</div>
                <div class="col-md-8">@Model.Route.BusStation?.Name</div>
            </div>
            <div class="row mb-2">
                <div class="col-md-4 fw-bold">From</div>
                <div class="col-md-8">@Model.Route.BusStation?.Town</div>
            </div>


            <div class="row mb-2">
                <div class="col-md-4 fw-bold">To</div>
                <div class="col-md-8">
                    @Model.Route.DestinationTown (@Model.Route.DestinationCountry)
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-4 fw-bold">Departure time</div>
                <div class="col-md-8">
                    @Model.Route.DepartureTime.ToString("dd.MM.yyyy HH:mm")
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-4 fw-bold">Price</div>
                <div class="col-md-8">
                    @Model.Route.Price MKD
                </div>
            </div>

            <div class="row mb-2">
                <div class="col-md-4 fw-bold">Available seats</div>
                <div class="col-md-8">
                    @Model.Route.AvailableSeats
                </div>
            </div>

            

        </div>
    </div>

    <!-- ACTION BUTTONS -->
    <div class="mt-4 d-flex gap-2 flex-wrap">

        @if (User.IsInRole("Admin"))
{
    if (Model.Tickets != null && Model.Tickets.Any())
    {
        <a asp-action="Reservations"
           asp-route-id="@Model.Route.Id"
           class="btn btn-info">
            View tickets (@Model.Tickets.Count())
        </a>
    }
    else
    {
        <span class="text-muted align-self-center">
            No tickets yet
        </span>
    }

    <a asp-action="Edit"
       asp-route-id="@Model.Route.Id"
       class="btn btn-warning">
        Edit route
    </a>

    <a asp-action="Delete"
       asp-route-id="@Model.Route.Id"
       class="btn btn-danger">
        Delete route
    </a>
}


        <a asp-action="Index"
           class="btn btn-outline-secondary">
            Back to routes
        </a>

    </div>

</div>
