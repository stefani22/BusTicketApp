                <input asp-for="EstimatedHours" class="form-control" />
                <span asp-validation-for="EstimatedHours" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="BusStationId" class="control-label"></label>
                <select asp-for="BusStationId" class="form-control" asp-items="ViewBag.BusStationId"></select>
                <span asp-validation-for="BusStationId" class="text-danger"></span>
            </div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
